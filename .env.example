# Copy to .env and fill in real values. NEVER commit .env.

# Unison API — where the eval-turn endpoint lives
UNISON_API_URL=http://localhost:3001

# UNISON_EVAL_SECRET — the PRIMARY auth for runs against a deployed Unison
#. Set it to the server master secret (or a per-reproducer access
# token issued via /eval/request-token). When set, the unison-agent adapter
# sends it as X-Unison-Eval and provisions a fresh ephemeral tenant per question
# — no Supabase JWT needed. Required for prod runs; leave blank for the
# localhost-bypass dev path.
UNISON_EVAL_SECRET=

# UNISON_JWT can be left blank when running against a local Unison instance.
# In that case, the local Unison must have UNISON_LOCAL_EVAL_TENANT_ID set
# in its env (local-eval bypass; the adapter then skips the Authorization header).
# The adapter auto-detects localhost URLs and skips the Authorization header.
UNISON_JWT=

# Anthropic — for the LLM judge AND for Claude Code adapter cost accounting
ANTHROPIC_API_KEY=sk-ant-...

# Judge model. Pinned per release for reproducibility.
JUDGE_MODEL=claude-opus-4-5-20250101

# Default timeouts (seconds)
ADAPTER_TIMEOUT=120
JUDGE_TIMEOUT=60

# Concurrency for parallel question runs
MAX_CONCURRENT_QUESTIONS=3

# Server (FastAPI) port
SERVER_PORT=8001

# Optional: HuggingFace dataset cache override
HF_HOME=~/.cache/huggingface

# pgvector_naive adapter — local Postgres with pgvector extension
# Spin up locally: docker run -d --name pgvec -p 5433:5432 -e POSTGRES_PASSWORD=evals pgvector/pgvector:pg17
PGVECTOR_DSN=postgres://postgres:evals@localhost:5433/postgres

# OpenAI — for pgvector_naive embeddings (text-embedding-3-small) and the optional
# GPT-as-judge mode (default judge is Claude).
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Mem0 cloud — needed for mem0 (BrainAdapter) + mem0-agent (AgentAdapter)
MEM0_API_KEY=

# Letta cloud (or leave LETTA_BASE_URL set for self-hosted)
LETTA_API_KEY=
LETTA_BASE_URL=
LETTA_AGENT_MODEL=openai/gpt-4o-mini
LETTA_AGENT_EMBEDDING=openai/text-embedding-3-small

# Zep cloud (or leave ZEP_BASE_URL set for self-hosted)
ZEP_API_KEY=
ZEP_BASE_URL=
ZEP_INGEST_WAIT_SECONDS=10.0

# Google Gemini — for google-gemini adapter (no-memory baseline)
GOOGLE_API_KEY=

# OpenAI chat model — for openai-gpt5 adapter (no-memory baseline)
# The OPENAI_API_KEY above is reused; this controls which model is called.
OPENAI_CHAT_MODEL=gpt-5

# Gemini model — for google-gemini adapter
GEMINI_MODEL=gemini-2.5-pro

# Codex CLI auth — install + authenticate before running the codex adapter:
#   npm install -g @openai/codex   (or: brew install --cask codex)
#   codex login
# The CLI also picks up OPENAI_API_KEY automatically if set.

# Gemini CLI auth — install + authenticate before running the gemini-cli adapter:
#   npm install -g @google/gemini-cli
#   gemini auth login
# The CLI also picks up GOOGLE_API_KEY automatically if set.

# tau-bench mode-B only (local, direct DB): comma-separated tenant-scoped tables
# your server wipes between tasks, in FK-safe order. Leave blank otherwise.
# UNISON_RESET_TABLES=
